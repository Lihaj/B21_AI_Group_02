    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "cypress-cucumber-preprocessor": {
    "nonGlobalStepDefinitions": false,
    "stepDefinitions": [
      "cypress/e2e/step_definitions/**/*.ts"
    ]
  }
